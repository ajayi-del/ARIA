# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# ARIA v1.3 вЂ” Environment Configuration
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# TWO BOT INSTANCES:
#   ARIA    в†’ MODE=live      (real trades, SoDEX mainnet)
#   Phantom в†’ MODE=paper     (simulated trades, paper balance)
#
# Run ARIA:    MODE=live    python main.py
# Run Phantom: MODE=paper   python main.py
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

# в”Ђв”Ђ Bot Mode в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
MODE=live
DATA_SOURCE=bybit

# в”Ђв”Ђ SoDEX Account в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Wallet address (hex) вЂ” used for REST balance/position queries
SODEX_ACCOUNT_ID=0xdb87899C08eA8A5C7cFCe2211a487C889B58A869
# Private key for EIP-712 order signing
SODEX_PRIVATE_KEY=0xab3eb016fd12447c7095b5a5f56bbecbcd066e2fb3df12a4ace93836e417e9b4
# Numeric Account ID (aid) вЂ” fetched dynamically at startup from
#   GET /api/v1/spot/accounts/{address}/state в†’ data.aid
# aid=0 means wallet not yet registered on SoDEX (deposit USDC to register).
# ARIA resolves this automatically; this field is for reference only.
# SODEX_NUMERIC_AID=0

SODEX_MAINNET=true
LIVE_MODE_CONFIRMED=true

# в”Ђв”Ђ SoDEX Mainnet Endpoints в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
MAINNET_REST_URL=https://mainnet-gw.sodex.dev/api/v1
MAINNET_WS_SPOT=wss://mainnet-gw.sodex.dev/ws/spot
MAINNET_WS_PERPS=wss://mainnet-gw.sodex.dev/ws/perps
CHAIN_ID_MAINNET=286623

# в”Ђв”Ђ Fee Intelligence (v1.5) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# SOSO tokens staked for trading fee discount.
# 0=no discount, 300=10%, 3000=15%, 30000=20%, 300000=50%
SOSO_STAKED=168

# в”Ђв”Ђ Risk & Strategy в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
DEFAULT_LEVERAGE=6
RISK_PCT=0.015
MIN_COHERENCE=2.0
MAX_DAILY_LOSS_PCT=0.05
ARB_CAPITAL_PCT=0.20
ASSETS=["BTC-USD", "ETH-USD", "SOL-USD", "XAUT-USD", "BNB-USD", "LINK-USD", "AVAX-USD", "SUI-USD", "ARB-USD", "OP-USD", "NEAR-USD", "MNT-USD", "1000PEPE-USD", "XRP-USD", "TRUMP-USD", "BASED-USD", "CL-USD", "COPPER-USD", "TSM-USD", "ORCL-USD", "NVDA-USD", "MSFT-USD", "AAPL-USD", "AMZN-USD", "GOOGL-USD", "META-USD", "TSLA-USD"]

# в”Ђв”Ђ DrawdownManager (v1.6) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
MAX_TOTAL_DRAWDOWN=0.25
MAX_WEEKLY_DRAWDOWN=0.15
DRAWDOWN_RECOVERY_THRESHOLD=0.10

# в”Ђв”Ђ Session Drawdown Gate (v1.7) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Regimes trigger on session peak-to-trough drawdown:
#   caution   вЂ” TP1 only, no runners
#   defensive вЂ” TP1 at 50% distance, no runners
#   halt      вЂ” no new entries allowed
DD_CAUTION_PCT=2.0
DD_DEFENSIVE_PCT=4.5
DD_HALT_PCT=8.0
MAX_CONSECUTIVE_LOSSES=4

# в”Ђв”Ђ Fixed Floor Sizing (mainnet) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Replaces Kelly on small accounts. base_trade_usd=0 reverts to Kelly.
# Mainnet target: $200 notional per trade = $20 margin at 10x.
# Conviction-scaled: scoreв‰Ґ3.0 в†’ 1.4Г— = $280; scoreв‰Ґ5.0 в†’ 2.0Г— = $300 (capped).
# MIN_TRADE_USD / MIN_TRADE_NOTIONAL_USD = SoDEX dust guard only (~$50 minimum).
# temporal_mult is logged but NOT applied to size вЂ” full $200 base preserved always.
BASE_TRADE_USD=200.0
MIN_TRADE_USD=50.0
MAX_TRADE_USD=300.0
MIN_TRADE_NOTIONAL_USD=50.0
MAX_DAILY_TRADES=40
TARGET_DAILY_TRADES=20

# в”Ђв”Ђ Stop / Trail parameters в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# stop_atr_mult: 1.5Г— ATR + 0.8% price floor (wider than 0.5% to survive 30-min holds)
# 0.5% was too tight вЂ” AVAX/LINK noise hits it in seconds on thin SoDEX books
STOP_ATR_MULT=1.5
TRAIL_ACTIVATION_ATR=0.5
TRAIL_DISTANCE_ATR=0.5

# в”Ђв”Ђ Phantom (Paper Mode) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Starting balance for Phantom paper trading simulation
PAPER_STARTING_BALANCE=200.0
