# ═══════════════════════════════════════════════════════════════
# ARIA v1.3 — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# TWO BOT INSTANCES:
#   ARIA    → MODE=live      (real trades, SoDEX mainnet)
#   Phantom → MODE=paper     (simulated trades, paper balance)
#
# Run ARIA:    MODE=live    python main.py
# Run Phantom: MODE=paper   python main.py
# ═══════════════════════════════════════════════════════════════

# ── Bot Mode ─────────────────────────────────────────────────
MODE=live
DATA_SOURCE=bybit

# ── SoDEX Account ────────────────────────────────────────────
# Wallet address (hex) — used for REST balance/position queries
SODEX_ACCOUNT_ID=0xdb87899C08eA8A5C7cFCe2211a487C889B58A869
# Private key for EIP-712 order signing
SODEX_PRIVATE_KEY=0xab3eb016fd12447c7095b5a5f56bbecbcd066e2fb3df12a4ace93836e417e9b4
# Numeric Account ID (aid) — fetched dynamically at startup from
#   GET /api/v1/spot/accounts/{address}/state → data.aid
# aid=0 means wallet not yet registered on SoDEX (deposit USDC to register).
# ARIA resolves this automatically; this field is for reference only.
# SODEX_NUMERIC_AID=0

SODEX_MAINNET=true
LIVE_MODE_CONFIRMED=true

# ── SoDEX Mainnet Endpoints ──────────────────────────────────
MAINNET_REST_URL=https://mainnet-gw.sodex.dev/api/v1
MAINNET_WS_SPOT=wss://mainnet-gw.sodex.dev/ws/spot
MAINNET_WS_PERPS=wss://mainnet-gw.sodex.dev/ws/perps
CHAIN_ID_MAINNET=286623

# ── SLP Vault + SOSO Staking ────────────────────────────────
# sMAG7.ssi tokens deposited in the SLP vault (manually deposited on SSI.sosovalue.com).
# This is the definitive quantity used for yield accounting and SOVEREIGN territory display.
SLP_VAULT_SMAG7_DEPOSITED=375.5
# SLP_VAULT_ENTRY_DATE=2026-01-01   # ISO date of deposit
# SLP_VAULT_ENTRY_USD=0             # USD value at entry
# SLP_VAULT_SMAG7_ENTRY_PRICE=0     # MAG7SSI price at entry (auto-set on first price tick)

# ── Fee Intelligence (v1.5) ─────────────────────────────────
# SOSO tokens staked for trading fee discount.
# 0=no discount, 300=10%, 3000=15%, 30000=20%, 300000=50%
SOSO_STAKED=168

# ── Risk & Strategy ──────────────────────────────────────────
DEFAULT_LEVERAGE=5
RISK_PCT=0.03
MIN_COHERENCE=5.0
MAX_DAILY_LOSS_PCT=0.05
ARB_CAPITAL_PCT=0.20
ASSETS=["BTC-USD", "ETH-USD", "SOL-USD", "XAUT-USD", "BNB-USD", "LINK-USD", "AVAX-USD", "SUI-USD", "ARB-USD", "OP-USD", "NEAR-USD", "1000PEPE-USD", "XRP-USD", "TRUMP-USD", "BASED-USD", "LTC-USD", "CL-USD", "SILVER-USD", "CRCL-USD", "COIN-USD", "DOGE-USD", "HBAR-USD", "COPPER-USD", "TSM-USD", "ORCL-USD", "NVDA-USD", "MSFT-USD", "AAPL-USD", "AMZN-USD", "GOOGL-USD", "META-USD", "TSLA-USD", "USTECH100-USD", "SPCX-USD"]

# ── DrawdownManager (v1.6) ───────────────────────────────────
MAX_TOTAL_DRAWDOWN=0.25
MAX_WEEKLY_DRAWDOWN=0.15
DRAWDOWN_RECOVERY_THRESHOLD=0.10

# ── Session Drawdown Gate (v1.7) ─────────────────────────────
# Regimes trigger on session peak-to-trough drawdown:
#   caution   — TP1 only, no runners
#   defensive — TP1 at 50% distance, no runners
#   halt      — no new entries allowed
DD_CAUTION_PCT=2.0
DD_DEFENSIVE_PCT=4.5
DD_HALT_PCT=8.0
MAX_CONSECUTIVE_LOSSES=4

# ── Fixed Floor Sizing (mainnet) ─────────────────────────────
# Replaces Kelly on small accounts. base_trade_usd=0 reverts to Kelly.
# Mainnet target: $200 notional per trade = $20 margin at 10x.
# Conviction-scaled: score≥3.0 → 1.4× = $280; score≥5.0 → 2.0× = $300 (capped).
# MIN_TRADE_USD / MIN_TRADE_NOTIONAL_USD = strategy floor ($80). SoDEX exchange hard floor is $50
# (enforced separately in sodex_client.py). $80 ensures meaningful margin ($16 at 5×).
# temporal_mult is logged but NOT applied to size — full $200 base preserved always.
BASE_TRADE_USD=200.0
MIN_TRADE_USD=80.0
MAX_TRADE_USD=300.0
MIN_TRADE_NOTIONAL_USD=80.0
MAX_DAILY_TRADES=40
TARGET_DAILY_TRADES=20

# ── Stop / Trail parameters ───────────────────────────────────
# stop_atr_mult: 1.5× ATR + 0.8% price floor (wider than 0.5% to survive 30-min holds)
# 0.5% was too tight — AVAX/LINK noise hits it in seconds on thin SoDEX books
STOP_ATR_MULT=1.5
TRAIL_ACTIVATION_ATR=2.0
TRAIL_DISTANCE_ATR=1.0

# ── Phantom (Paper Mode) ─────────────────────────────────────
# Starting balance for Phantom paper trading simulation
PAPER_STARTING_BALANCE=200.0
