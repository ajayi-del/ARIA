# ARIA Configuration
# Copy this to .env and edit values

# Mode: paper | testnet | live
MODE=paper

# Assets to monitor (comma separated)
ASSETS=BTC,ETH,SOL,XAUT

# Data settings
ORDERBOOK_MAX_AGE_MS=500
CANDLE_BUFFER_SIZE=200
LOOP_INTERVAL_MS=1000

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Execution Layer - REQUIRED FOR TESTNET/LIVE
PRIVATE_KEY=
ACCOUNT_ID=

# Live Mode Confirmation (set to "true" only for production)
LIVE_MODE_CONFIRMED=

# LLM Review (weekly review only)
ANTHROPIC_API_KEY=

# Risk Management
LIVE_RISK_PCT=0.02
LIVE_MIN_COHERENCE=4
MIN_RR_RATIO=2.0
DEFAULT_LEVERAGE=10
