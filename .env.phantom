# ═══════════════════════════════════════════════════════════════
# Phantom (Paper Bot) — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Run with: MODE=paper python main.py  OR
#           env $(cat .env.phantom | xargs) python main.py
# ═══════════════════════════════════════════════════════════════

# ── Bot Mode ─────────────────────────────────────────────────
MODE=paper
DATA_SOURCE=bybit

# ── Identity (same keys — Phantom reads SoDEX marks, never signs orders) ────
SODEX_ACCOUNT_ID=0xdb87899C08eA8A5C7cFCe2211a487C889B58A869
SODEX_PRIVATE_KEY=0x80ed91ee71b45e21dd85dcd9fae446d437cacd145dc350006ca04973c7706e4e
SODEX_MAINNET=true
LIVE_MODE_CONFIRMED=true

# ── SoDEX Mainnet Endpoints ──────────────────────────────────
MAINNET_REST_URL=https://mainnet-gw.sodex.dev/api/v1
MAINNET_WS_SPOT=wss://mainnet-gw.sodex.dev/ws/spot
MAINNET_WS_PERPS=wss://mainnet-gw.sodex.dev/ws/perps
CHAIN_ID_MAINNET=286623

TESTNET_REST_URL=https://testnet-gw.sodex.dev/api/v1
TESTNET_WS_SPOT=wss://testnet-gw.sodex.dev/ws/spot
TESTNET_WS_PERPS=wss://testnet-gw.sodex.dev/ws/perps
CHAIN_ID_TESTNET=138565

# ── Risk & Strategy ──────────────────────────────────────────
DEFAULT_LEVERAGE=3
RISK_PCT=0.01
MIN_COHERENCE=3
ARB_CAPITAL_PCT=0.20
ASSETS=["BTC-USD", "ETH-USD", "SOL-USD", "XAUT-USD", "BNB-USD", "LINK-USD", "AVAX-USD"]

# ── Phantom Starting Balance ──────────────────────────────────
PAPER_STARTING_BALANCE=200.0
